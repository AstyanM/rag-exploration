import re
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_core.documents import Document

def chunk_avec_numeros_de_lignes(texte_numerote, metadonnees_base, chunk_size=500, chunk_overlap=50):
    lignes_propres = []
    correspondance_lignes = [] # Va stocker: index_ligne_propre -> vrai_numero_de_ligne
    
    # 1. Extraction et séparation
    for ligne in texte_numerote.split('\n'):
        # Cherche le format "  12 | int main() {"
        match = re.match(r'^[ \t]*(\d+)[ \t]*\|[ \t]*(.*)', ligne)
        
        if match:
            vrai_numero = int(match.group(1))
            code_propre = match.group(2)
        else:
            # Sécurité au cas où une ligne n'aurait pas de numéro
            vrai_numero = correspondance_lignes[-1] + 1 if correspondance_lignes else 1
            code_propre = ligne
            
        lignes_propres.append(code_propre)
        correspondance_lignes.append(vrai_numero)
        
    # On recrée le code 100% propre pour LangChain
    texte_propre_complet = '\n'.join(lignes_propres)
    
    # 2. Configuration du Splitter (add_start_index est CRUCIAL ici)
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=chunk_size,
        chunk_overlap=chunk_overlap,
        add_start_index=True # Demande à LangChain de noter l'index du caractère de départ
    )
    
    # On crée les chunks bruts
    chunks_bruts = splitter.create_documents([texte_propre_complet])
    documents_finaux = []
    
    # 3. Réconciliation des métadonnées avec les numéros de ligne
    for chunk in chunks_bruts:
        # Index en nombre de caractères
        char_debut = chunk.metadata['start_index']
        char_fin = char_debut + len(chunk.page_content)
        
        # Astuce : le numéro de la ligne correspond au nombre de sauts de ligne (\n) 
        # qu'il y a eu avant ce caractère dans le grand texte.
        idx_ligne_debut = texte_propre_complet.count('\n', 0, char_debut)
        
        # Le -1 évite de compter la ligne suivante si le chunk s'arrête pile sur un \n
        idx_ligne_fin = texte_propre_complet.count('\n', 0, max(0, char_fin - 1))
        
        # Création des métadonnées finales
        meta = metadonnees_base.copy()
        meta.update({
            "start_line": correspondance_lignes[idx_ligne_debut],
            "end_line": correspondance_lignes[idx_ligne_fin]
        })
        
        # Création du document LangChain propre et enrichi
        doc = Document(
            page_content=chunk.page_content,
            metadata=meta
        )
        documents_finaux.append(doc)
        
    return documents_finaux

# --- TEST ---

texte_test = """  15 | #include <stdio.h>
  16 | 
  17 | int main() {
  18 |     printf("Bonjour");
  19 |     return 0;
  20 | }"""

metadonnees_fichier = {"nom_fichier": "main.c"}

# On met un chunk_size très petit (30) pour forcer la découpe lors du test
mes_chunks = chunk_avec_numeros_de_lignes(texte_test, metadonnees_fichier, chunk_size=30, chunk_overlap=5)

for i, doc in enumerate(mes_chunks):
    print(f"--- Chunk {i+1} [Lignes {doc.metadata['start_line']} à {doc.metadata['end_line']}] ---")
    print(doc.page_content)
    print("-" * 35)
