import re
import tree_sitter_c as tsc
from tree_sitter import Language, Parser
from qdrant_client import QdrantClient

# ==========================================
# 1. INITIALIZATION
# ==========================================

# Initialize Tree-sitter for C Language
C_LANGUAGE = Language(tsc.language())
parser = Parser(C_LANGUAGE)

# Initialize Qdrant Client (running in-memory for this test)
# For production, use: client = QdrantClient(path="./qdrant_db")
client = QdrantClient(":memory:")

# Setup Qdrant to use FastEmbed for local vector generation
client.set_model("sentence-transformers/all-MiniLM-L6-v2")

# ==========================================
# 2. MOCK DATA (Your Cleaned C Code)
# ==========================================

numbered_c_code = """  1 | #include <stdio.h>
  2 | 
  3 | typedef enum {
  4 |     STATUS_OK,
  5 |     STATUS_ERROR
  6 | } SystemStatus;
  7 | 
  8 | struct DeviceConfig {
  9 |     int device_id;
 10 |     int baud_rate;
 11 | };
 12 | 
 13 | int initialize_device(struct DeviceConfig config) {
 14 |     if (config.device_id <= 0) {
 15 |         return STATUS_ERROR;
 16 |     }
 17 |     // Device init logic here
 18 |     return STATUS_OK;
 19 | }"""

# Your previously extracted metadata
file_metadata = {
    "file_name": "device_driver.c",
    "file_path": "/src/drivers/device_driver.c",
    "global_defines": {
        "MAX_BUFFER": {"val": "1024", "brief": "Max buffer size"},
    }
}

# ==========================================
# 3. CHUNKING LOGIC (Tree-sitter)
# ==========================================

def chunk_c_code_with_treesitter(numbered_text, metadata):
    """
    Strips line numbers for Tree-sitter, parses the AST, and maps 
    the boundaries back to the original numbered text.
    """
    lines = numbered_text.split('\n')
    
    # Strip line numbers temporarily to get valid C code for the parser
    # Matches patterns like "  14 | " or "1 | "
    clean_lines = [re.sub(r'^[ \t]*\d+[ \t]*\|[ \t]*', '', line) for line in lines]
    clean_code = '\n'.join(clean_lines)
    
    # Parse the clean code
    tree = parser.parse(bytes(clean_code, "utf8"))
    
    # Tree-sitter query to find functions, structs, and enums
    query_code = """
    (function_definition) @function
    (struct_specifier) @struct
    (enum_specifier) @enum
    """
    query = C_LANGUAGE.query(query_code)
    captures = query.captures(tree.root_node)
    
    chunks = []
    
    # Extract blocks using AST boundaries, but slice from the NUMBERED lines
    for node, tag in captures:
        start_line = node.start_point[0]
        end_line = node.end_point[0]
        
        chunk_lines = lines[start_line:end_line + 1]
        chunk_text = '\n'.join(chunk_lines)
        
        # Merge file metadata with chunk-specific metadata
        chunk_metadata = metadata.copy()
        chunk_metadata.update({
            "chunk_type": tag,
            "start_line": start_line + 1, # +1 because AST is 0-indexed
            "end_line": end_line + 1
        })
        
        chunks.append({
            "text": chunk_text,
            "metadata": chunk_metadata
        })
        
    return chunks

# Execute the chunker
document_chunks = chunk_c_code_with_treesitter(numbered_c_code, file_metadata)
print(f"Extracted {len(document_chunks)} logical chunks from the code.\n")

# ==========================================
# 4. INDEXING TO QDRANT
# ==========================================

COLLECTION_NAME = "c_code_knowledge_base"

# Recreate the collection (useful for iterative testing)
if client.collection_exists(COLLECTION_NAME):
    client.delete_collection(COLLECTION_NAME)

# Create collection (FastEmbed automatically configures the vector size)
client.create_collection(
    collection_name=COLLECTION_NAME,
    vectors_config=client.get_fastembed_vector_params()
)

# Prepare data for insertion
documents = [chunk["text"] for chunk in document_chunks]
metadata_list = [chunk["metadata"] for chunk in document_chunks]

# Insert chunks into Qdrant (vectors are generated automatically)
client.add(
    collection_name=COLLECTION_NAME,
    documents=documents,
    metadata=metadata_list
)
print(f"Successfully indexed {len(documents)} chunks into Qdrant collection: '{COLLECTION_NAME}'\n")

# ==========================================
# 5. RETRIEVAL TESTING (RAG)
# ==========================================

test_query = "How is the device configured and what are its properties?"
print(f"--- RUNNING TEST QUERY ---")
print(f"Query: '{test_query}'\n")

