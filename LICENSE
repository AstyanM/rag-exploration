import re
import uuid
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_core.documents import Document
from langchain.retrievers import ParentDocumentRetriever
from langchain.storage import InMemoryStore
from langchain_qdrant import QdrantVectorStore
from langchain_openai import OpenAIEmbeddings
from qdrant_client import QdrantClient
from qdrant_client.models import VectorParams, Distance

# ==========================================
# 1. CUSTOM PARENT CHUNKER (Line Numbers)
# ==========================================
def create_parent_chunks_with_line_numbers(numbered_text, base_metadata, chunk_size=800, chunk_overlap=0):
    """
    Cleans the line numbers from the text, splits it into large blocks (Parents),
    and strictly maps the start/end lines back to the metadata.
    """
    clean_lines = []
    line_mapping = [] # Maps clean text index -> actual original line number
    
    # Extract line numbers and clean code
    for line in numbered_text.split('\n'):
        match = re.match(r'^[ \t]*(\d+)[ \t]*\|[ \t]*(.*)', line)
        if match:
            real_number = int(match.group(1))
            clean_code = match.group(2)
        else:
            real_number = line_mapping[-1] + 1 if line_mapping else 1
            clean_code = line
            
        clean_lines.append(clean_code)
        line_mapping.append(real_number)
        
    full_clean_text = '\n'.join(clean_lines)
    
    # Split the clean text
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=chunk_size,
        chunk_overlap=chunk_overlap,
        add_start_index=True 
    )
    raw_chunks = splitter.create_documents([full_clean_text])
    
    parent_documents = []
    for chunk in raw_chunks:
        char_start = chunk.metadata['start_index']
        char_end = char_start + len(chunk.page_content)
        
        idx_line_start = full_clean_text.count('\n', 0, char_start)
        idx_line_end = full_clean_text.count('\n', 0, max(0, char_end - 1))
        
        meta = base_metadata.copy()
        meta.update({
            "start_line": line_mapping[idx_line_start],
            "end_line": line_mapping[idx_line_end],
            # We assign a manual UUID to trace the parent later in our visualization
            "doc_id": str(uuid.uuid4()) 
        })
        
        parent_documents.append(Document(page_content=chunk.page_content, metadata=meta))
        
    return parent_documents

# ==========================================
# 2. SETUP EMBEDDINGS & DATABASES
# ==========================================

# Using the configuration that bypassed your local server errors (768 dimensions)
embeddings_model = OpenAIEmbeddings(
    openai_api_base="http://YOUR_LOCAL_ENDPOINT/v1", 
    openai_api_key="empty_key", 
    model="default_local_model", 
    check_embedding_ctx_length=False # The kill-switch
)

# Qdrant for Small Vectors (Children)
qdrant_client = QdrantClient(":memory:")
COLLECTION_NAME = "c_code_children"

if qdrant_client.collection_exists(COLLECTION_NAME):
    qdrant_client.delete_collection(COLLECTION_NAME)

qdrant_client.create_collection(
    collection_name=COLLECTION_NAME,
    vectors_config=VectorParams(size=768, distance=Distance.COSINE) 
)

vectorstore = QdrantVectorStore(
    client=qdrant_client,
    collection_name=COLLECTION_NAME,
    embedding=embeddings_model
)

# RAM Store for Large Texts (Parents)
store_parents = InMemoryStore()

# ==========================================
# 3. CONFIGURE PARENT/CHILD RETRIEVER
# ==========================================

# The child splitter: cuts the parents into tiny 200-char pieces for precise search
child_splitter = RecursiveCharacterTextSplitter(chunk_size=200, chunk_overlap=20)

retriever = ParentDocumentRetriever(
    vectorstore=vectorstore,
    docstore=store_parents,
    child_splitter=child_splitter,
    parent_splitter=None, # None! Because we already built our Parents manually!
    search_kwargs={"k": 1} # Return only the top 1 Parent for clarity
)

# ==========================================
# 4. INGESTION PROCESS
# ==========================================

# Dummy C-Code with line numbers
dummy_c_code = """  10 | #include <stdio.h>
  11 | 
  12 | // Configuration Struct
  13 | struct Config {
  14 |     int max_retries;
  15 |     int timeout_ms;
  16 | };
  17 | 
  18 | int initialize_system(struct Config c) {
  19 |     if (c.max_retries > 5) {
  20 |         printf("Warning: High retries");
  21 |     }
  22 |     return 0;
  23 | }"""

file_metadata = {"file_name": "system.c", "defines": "MAX_RETRIES 5"}

print("1. Creating logical Parent chunks with line numbers...")
# We use a small chunk_size (100) just to force multiple parents in this small test
parents = create_parent_chunks_with_line_numbers(dummy_c_code, file_metadata, chunk_size=100)

print(f"-> Generated {len(parents)} Parent Documents.")

print("2. Ingesting into Retriever (Creating vector children automatically)...")
# We manually extract the doc_ids to tell LangChain exactly how to link them
doc_ids = [doc.metadata["doc_id"] for doc in parents]
retriever.add_documents(parents, ids=doc_ids)
print("-> Ingestion complete!\n")

# ==========================================
# 5. VISUALIZATION & RETRIEVAL (Under the Hood)
# ==========================================

query = "What happens if there are too many max_retries?"
print(f"=== SEARCH QUERY: '{query}' ===\n")

# A. UNDER THE HOOD: What did Qdrant actually find? (The Child)
# We search directly in the vectorstore to see the tiny chunk that triggered the match
raw_vector_results = vectorstore.similarity_search_with_score(query, k=1)
best_child_doc, child_score = raw_vector_results[0]
parent_id_triggered = best_child_doc.metadata['doc_id']

print("🔍 1. THE CHILD MATCH (What Qdrant found using Embeddings):")
print(f"   Score: {child_score:.4f}")
print(f"   Snippet: '{best_child_doc.page_content}'")
print(f"   Belongs to Parent ID: {parent_id_triggered}\n")

# B. THE FINAL OUTPUT: What the Retriever actually returns to the LLM? (The Parent)
# We use the retriever normally
final_results = retriever.invoke(query)
final_parent = final_results[0]

print("📦 2. THE PARENT RETURNED (What the LLM will actually read):")
print(f"   File: {final_parent.metadata['file_name']}")
print(f"   Lines: {final_parent.metadata['start_line']} to {final_parent.metadata['end_line']}")
print("   Full Context:")
print("-" * 40)
print(final_parent.page_content)
print("-" * 40)
