import requests
import time

API_KEY = "VOTRE_CLE_API"
BASE_URL = "https://votre-url.com/v1/embeddings" # Assurez-vous que c'est l'URL complète qui finit par /embeddings

headers = {
    "Authorization": f"Bearer {API_KEY}",
    "Content-Type": "application/json"
}

# La méga-liste des modèles d'embeddings probables
modeles_a_tester = [
    # --- Famille BAAI (BGE) - Très probable vu la dimension 768 ---
    "BAAI/bge-base-en-v1.5", "bge-base-en-v1.5", "bge-base",
    "BAAI/bge-large-en-v1.5", "bge-large-en-v1.5", "bge-large",
    "BAAI/bge-small-en-v1.5", "bge-small-en-v1.5", "bge-small",
    "BAAI/bge-m3", "bge-m3",
    
    # --- Famille Sentence-Transformers (Classiques) ---
    "sentence-transformers/all-mpnet-base-v2", "all-mpnet-base-v2",
    "sentence-transformers/all-MiniLM-L6-v2", "all-MiniLM-L6-v2",
    "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2", "paraphrase-multilingual-MiniLM-L12-v2",
    
    # --- Famille Jina AI (Spécialistes du code et multilingue) ---
    "jina-embeddings-v2-base-en", "jina-embeddings-v2-base-code",
    "jina-embeddings-v2-base-fr", "jina-embeddings-v3",
    "jinaai/jina-embeddings-v2-base-en", "jinaai/jina-embeddings-v2-base-code",
    
    # --- Famille Nomic ---
    "nomic-embed-text", "nomic-ai/nomic-embed-text-v1.5",
    
    # --- Famille Microsoft / E5 ---
    "intfloat/multilingual-e5-base", "multilingual-e5-base",
    "intfloat/multilingual-e5-large", "multilingual-e5-large",
    "intfloat/e5-base-v2", "e5-base-v2",
    
    # --- Modèles d'API standard (si c'est un proxy LiteLLM) ---
    "text-embedding-ada-002", "text-embedding-3-small", "text-embedding-3-large",
    "mistral-embed", "cohere/embed-multilingual-v3.0", "cohere/embed-english-v3.0",
    "voyage-code-2", "voyage-large-2",
    
    # --- Modèles Ollama fréquents ---
    "mxbai-embed-large", "snowflake-arctic-embed",
    
    # --- Noms génériques de fallback ---
    "default", "embedding", "embeddings", "model"
]

print(f"Début du scan de {len(modeles_a_tester)} modèles...\n")

modeles_decouverts = []

for model in modeles_a_tester:
    payload = {
        "input": "Ceci est un test pour vérifier la disponibilité du modèle.",
        "model": model
    }
    
    try:
        response = requests.post(BASE_URL, headers=headers, json=payload, timeout=5)
        
        # Si on obtient 200, le modèle existe et est accepté !
        if response.status_code == 200:
            print(f"✅ BINGO ! Modèle disponible : {model}")
            modeles_decouverts.append(model)
        
        # Si erreur de droits (401/403), on prévient
        elif response.status_code in [401, 403]:
            print(f"⚠️ Modèle '{model}' trouvé mais accès refusé (401/403).")
            modeles_decouverts.append(f"{model} (Accès restreint)")
            
    except Exception as e:
        print(f"Erreur de connexion pour {model} : {e}")
        
    # Petite pause pour ne pas surcharger le serveur ou se faire bannir (Rate Limit)
    time.sleep(0.2) 

print("\n" + "="*40)
print("RÉSULTAT DU SCAN :")
if modeles_decouverts:
    for m in modeles_decouverts:
        print(f" - {m}")
else:
    print("Aucun modèle trouvé. Il est possible que le nom du modèle soit personnalisé par votre entreprise (ex: 'mon-embedding-v1').")
